#!/bin/sh
# .githooks/pre-commit
#
# コミット前に recent-pages.js を再生成し、変更があれば自動的にステージする。
# これにより「新規ページを作っても新着コンテンツに出ない」バグを根絶する。
#
# 有効化方法（リポジトリごとに1回だけ実行）:
#   git config core.hooksPath .githooks

set -e

if ! command -v node >/dev/null 2>&1; then
  echo "[pre-commit] node が見つからないため recent-pages.js の自動同期をスキップしました"
  exit 0
fi

# プロジェクトルートに移動（git のトップレベル）
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

if [ ! -f scripts/sync-recent-pages.js ]; then
  exit 0
fi

# 1) recent-pages.js を自動再生成
node scripts/sync-recent-pages.js > /dev/null
if ! git diff --quiet recent-pages.js 2>/dev/null; then
  git add recent-pages.js
  echo "[pre-commit] recent-pages.js を自動更新してステージしました"
fi

# 2) articles-gl-*.html の「関連ページ」ブロックを自動再生成
if [ -f scripts/sync-related-articles.js ]; then
  node scripts/sync-related-articles.js > /dev/null
  changed=$(git diff --name-only -- 'pages/articles-gl-*.html' 2>/dev/null)
  if [ -n "$changed" ]; then
    echo "$changed" | xargs git add
    n=$(echo "$changed" | wc -l | tr -d ' ')
    echo "[pre-commit] 関連ページブロックを ${n} ファイルで自動更新してステージしました"
  fi
fi

# 3) ページ整合性監査は pre-commit から外す
# audit-pages.js は .claude/worktrees/ をフルスキャン + 各ファイルで git ls-files exec を行い
# 約 17 秒消費 + 出力 70KB（436 件の worktree leftover 誤検出）を毎回発生させていた。
# その結果、コミット結果確認に追加の bash 呼び出しが必要になり 1 コミット往復が 5 倍に。
# 必要時は手動で `node scripts/audit-pages.js` を実行する。

exit 0
