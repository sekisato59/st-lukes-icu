#!/bin/sh
# .githooks/pre-commit
#
# コミット前に recent-pages.js を再生成し、変更があれば自動的にステージする。
# これにより「新規ページを作っても新着コンテンツに出ない」バグを根絶する。
#
# 有効化方法（リポジトリごとに1回だけ実行）:
#   git config core.hooksPath .githooks

set -e

if ! command -v node >/dev/null 2>&1; then
  echo "[pre-commit] node が見つからないため recent-pages.js の自動同期をスキップしました"
  exit 0
fi

# プロジェクトルートに移動（git のトップレベル）
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

if [ ! -f scripts/sync-recent-pages.js ]; then
  exit 0
fi

# 1) recent-pages.js を自動再生成
node scripts/sync-recent-pages.js > /dev/null
if ! git diff --quiet recent-pages.js 2>/dev/null; then
  git add recent-pages.js
  echo "[pre-commit] recent-pages.js を自動更新してステージしました"
fi

# 2) ページ整合性監査（worktree leftover / 略語ポップアップ漏れ）
if [ -f scripts/audit-pages.js ]; then
  audit_out=$(node scripts/audit-pages.js 2>&1)
  audit_exit=$?
  # 問題があれば警告のみ表示（コミットはブロックしない・--strict ではないため exit 0 のまま）
  if echo "$audit_out" | grep -qE "Worktree leftover|略語一覧あり/abbr-tooltip"; then
    echo ""
    echo "⚠ [pre-commit] ページ監査で問題を検出しました："
    echo "$audit_out" | grep -E "^\[|^  -" | sed 's/^/  /'
    echo ""
    echo "  詳細は: node scripts/audit-pages.js"
    echo ""
  fi
fi

exit 0
